archive_internal/
target/
node_modules/
dist/
*.log
.env
.env.local
**/*.rs.bk
Cargo.lock.bak

# insta pending snapshots — review with `cargo insta`, never commit
*.snap.new

# Tauri auto-generated files
src-tauri/gen/

# Binary build artifacts and downloaded runtime dependencies.
# `whisper-server.exe` and friends are fetched at first-run by
# `wizard_download_server` into `%LOCALAPPDATA%\phoneme\bin\`; nothing
# in the workspace should be checking them into git.
*.exe
*.dll
*.zip
*.wav
whisper-bin/

# pnpm 10 auto-generates frontend/pnpm-workspace.yaml as a placeholder stub
# ("allowBuilds: esbuild: set this to true or false") whenever it approves a
# build script. CI uses pnpm 9, where build approval lives in
# frontend/package.json (pnpm.onlyBuiltDependencies). A workspace file with no
# `packages:` field makes `pnpm install` fail on CI ("packages field missing"),
# so this locally-regenerated stub must never be committed.
frontend/pnpm-workspace.yaml
