# =============================================================================
# Phoneme — example environment variables
# =============================================================================
#
# These are the RUNTIME environment variables Phoneme reads (the daemon, the CLI,
# and the tray). They are read straight from the process environment — Phoneme
# does NOT auto-load a .env file, so this is documentation: set the variable in
# your shell, your service definition, or your launcher. Build-time variables
# (CARGO_*, the compiled-in CARGO_PKG_VERSION) are intentionally not listed —
# they affect compilation, not a running install.
#
# API keys are NOT environment variables. Provider keys are entered through
# Settings in the app (or `phoneme config set`) and stored DPAPI-encrypted in
# config.toml — never put a real API key here.
# =============================================================================


# --- Config & data location --------------------------------------------------

# PHONEME_CONFIG — override the active config.toml path. Honored by the daemon,
# the CLI, and the tray so all three agree on which file is live. Empty/unset
# falls back to the per-user default (%APPDATA%\phoneme\config.toml on Windows).
# A non-empty value that doesn't exist or doesn't parse fails loudly.
# PHONEME_CONFIG=C:\Users\you\phoneme\config.toml

# PHONEME_DATA_LOCAL — override the local data directory that holds the inbox
# queue, the catalog database, and the logs. Unset = the per-user default
# (%LOCALAPPDATA%\phoneme on Windows). Primarily used by integration tests to
# isolate concurrent daemons, but it is a real runtime override.
# PHONEME_DATA_LOCAL=C:\Users\you\phoneme\data


# --- Logging -----------------------------------------------------------------

# RUST_LOG — tracing filter for the daemon. When set, it OVERRIDES
# daemon.log_level from config.toml. Standard env-filter syntax, e.g.
# a bare level or a per-target filter.
# RUST_LOG=debug
# RUST_LOG=phoneme=debug,warn

# NO_COLOR — when set to ANY value, the `phoneme` CLI disables ANSI color in its
# output. (Equivalent to passing --no-color.) Following the no-color.org
# convention; presence is what matters, the value is ignored.
# NO_COLOR=1


# --- Model cache -------------------------------------------------------------

# HF_HOME — Hugging Face cache root. The doctor / diagnostics read this to locate
# downloaded models; unset, it falls back to the standard per-user HF cache under
# your home directory. Set it if you keep the HF cache somewhere non-default.
# HF_HOME=C:\Users\you\.cache\huggingface


# --- Testing / CI only -------------------------------------------------------

# PHONEME_AUDIO_BACKEND — set to "synthetic" to make the daemon use a generated
# audio source instead of real CPAL capture hardware. For integration tests and
# headless CI only; leave unset for normal use.
# PHONEME_AUDIO_BACKEND=synthetic


# --- Provided TO your hook scripts (not read FROM your environment) ----------
# When a hook command runs, Phoneme sets these in the hook process's environment
# so scripts can read them instead of parsing the JSON payload on stdin. You do
# not set these yourself — they are listed here for hook authors:
#   PHONEME_ID          — the recording id
#   PHONEME_AUDIO_PATH  — absolute path to the recording's .wav file
#   PHONEME_TRANSCRIPT  — the (post-processed) transcript text
