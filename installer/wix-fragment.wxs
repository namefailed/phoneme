<?xml version="1.0" encoding="utf-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Fragment>
    <!-- Add to PATH property, default enabled -->
    <Property Id="ADDTOPATH" Value="1" />

    <DirectoryRef Id="INSTALLDIR">
      <!-- Bundle phoneme-daemon and phoneme CLI -->
      <Component Id="PhonemeBinaries" Guid="4793155E-FEE7-4808-8D72-786050B871B5">
        <File Id="PhonemeDaemonExe" Name="phoneme-daemon.exe" Source="..\..\phoneme-daemon.exe" KeyPath="yes" />
        <File Id="PhonemeCliExe" Name="phoneme-cli.exe" Source="..\..\phoneme.exe" />
      </Component>

      <!-- PATH integration -->
      <Component Id="PhonemePathEntry" Guid="663CFD47-41A6-44A9-8F37-DC6F13F61198">
        <CreateFolder />
        <Condition>ADDTOPATH="1"</Condition>
        <Environment Id="PhonemePath"
                     Name="PATH"
                     Value="[INSTALLDIR]"
                     Permanent="no"
                     Part="last"
                     Action="set"
                     System="yes" />
      </Component>

      <!-- Component that materialises the hooks-templates directory. -->
      <Directory Id="HooksTemplatesDir" Name="hooks-templates">
        <Component Id="PhonemeHooksTemplates" Guid="2143BBDE-8E3F-403F-8D78-C006E1CED394">
          <File Id="HookStdout"   Name="to-stdout.ps1"        Source="..\..\..\..\hooks\to-stdout.ps1" KeyPath="yes" />
          <File Id="HookOrg"      Name="to-org-journal.ps1"   Source="..\..\..\..\hooks\to-org-journal.ps1" />
          <File Id="HookMarkdown" Name="to-markdown-daily.ps1" Source="..\..\..\..\hooks\to-markdown-daily.ps1" />
          <File Id="HookDenote"   Name="to-denote.ps1"        Source="..\..\..\..\hooks\to-denote.ps1" />
        </Component>
      </Directory>
    </DirectoryRef>
  </Fragment>
</Wix>
